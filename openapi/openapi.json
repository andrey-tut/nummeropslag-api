{
  "openapi": "3.1.0",
  "info": {
    "title": "Nummeropslag Partner API",
    "version": "0.4.9",
    "description": "Public Partner API for Danish phone-number lookup, caller-ID and spam/trust signals.\n\nAll data endpoints require an API key sent in the `X-API-Key` header. Get a key at https://nummeropslag.dk/api-noegle — each key has a plan, scopes (lookup / spam / operator) and a request quota.\n\nData core: official CVR (companies + production units) and the Danish number plan (SDFI, CC0). Privacy: names of private individuals are never exposed; contacts are never uploaded (GDPR)."
  },
  "paths": {
    "/api/v1/partner/lookup/{e164}": {
      "get": {
        "tags": [
          "partner-api"
        ],
        "summary": "Full lookup: company (CVR), operator, spam/trust, comments",
        "description": "Full record for a Danish number: registered company (CVR), telecom operator,\nspam/trust rating and recent anonymous comments.",
        "operationId": "partner_lookup_api_v1_partner_lookup__e164__get",
        "parameters": [
          {
            "name": "e164",
            "in": "path",
            "required": true,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "E164"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Api-Key"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NumberOut"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/partner/spam/{e164}": {
      "get": {
        "tags": [
          "partner-api"
        ],
        "summary": "Compact spam/trust verdict only",
        "description": "Lightweight spam/trust verdict — ideal for caller-ID / call-blocking.\nDB-only (live=False) → швидко: спам-вердикт із краудсорсу+БД, без блокуючого live-CVR.",
        "operationId": "partner_spam_api_v1_partner_spam__e164__get",
        "parameters": [
          {
            "name": "e164",
            "in": "path",
            "required": true,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "E164"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
